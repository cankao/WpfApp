<Application x:Class="WpfApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>

        <!-- Tipografia / cores base -->
        <SolidColorBrush x:Key="ReadOnlyBackground" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="PrimaryButtonBackground" Color="#D4EDDA"/>
        <SolidColorBrush x:Key="DangerButtonBackground" Color="#F8D7DA"/>
        <SolidColorBrush x:Key="AccentButtonBackground" Color="#CCE5FF"/>

        <!-- Botão padrão -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="Margin" Value="3,0,0,0"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- Botão primário (Salvar / Finalizar) -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBackground}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Botão destrutivo (Excluir / Remover) -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerButtonBackground}"/>
        </Style>

        <!-- Botão de ação destacada -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentButtonBackground}"/>
        </Style>

        <!-- Botão compacto (em linha com campos) -->
        <Style x:Key="InlineButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>

        <!-- Botão pequeno em célula de DataGrid -->
        <Style x:Key="GridActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="64"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
        </Style>

        <!-- TextBox padrão -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- TextBox somente leitura -->
        <Style x:Key="ReadOnlyTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="{StaticResource ReadOnlyBackground}"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Label -->
        <Style TargetType="Label">
            <Setter Property="Margin" Value="3,0,3,0"/>
            <Setter Property="Padding" Value="0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="3,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- GroupBox -->
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowHeight" Value="26"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserResizeColumns" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>

        <!-- Barra de botões no rodapé -->
        <Style x:Key="ActionBar" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

    </Application.Resources>
</Application>
