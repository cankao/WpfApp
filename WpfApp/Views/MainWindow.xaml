<Window x:Class="WpfApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WpfApp.Views"
        xmlns:vm="clr-namespace:WpfApp.ViewModels"
        Title="Cadastro - Pessoas, Produtos e Pedidos"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <TabControl Margin="6" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Pessoas">
                <views:PessoaView DataContext="{Binding PessoaVM}"/>
            </TabItem>
            <TabItem Header="Produtos">
                <views:ProdutoView DataContext="{Binding ProdutoVM}"/>
            </TabItem>
            <TabItem Header="Pedidos">
                <views:PedidoView DataContext="{Binding PedidoVM}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
