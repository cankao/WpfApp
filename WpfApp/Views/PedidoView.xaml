<UserControl x:Class="WpfApp.Views.PedidoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="520"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Column="0" Header="Novo Pedido">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label    Grid.Column="0" Content="Pessoa:"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Pessoas}"
                              DisplayMemberPath="Nome"
                              SelectedItem="{Binding PessoaSelecionada}"
                              IsEnabled="{Binding PodeEditar}"/>
                </Grid>

                <Grid Grid.Row="1" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label    Grid.Column="0" Content="Produto:"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Produtos}"
                              SelectedItem="{Binding ProdutoSelecionado}"
                              IsEnabled="{Binding PodeEditar}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Nome}"/>
                                    <Run Text=" (R$ "/>
                                    <Run Text="{Binding Valor, StringFormat=N2}"/>
                                    <Run Text=")"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Label   Grid.Column="2" Content="Qtd:" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="3" HorizontalContentAlignment="Right"
                             Text="{Binding QuantidadeAdicionar, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding PodeEditar}"/>
                    <Button  Grid.Column="4" Content="Adicionar"
                             Style="{StaticResource InlineButton}"
                             Command="{Binding AdicionarProdutoCommand}"/>
                </Grid>

                <Label Grid.Row="2" Content="Itens do Pedido:" FontWeight="Bold" Margin="0,8,0,2"/>

                <DataGrid Grid.Row="3"
                          ItemsSource="{Binding PedidoAtual.Itens}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código"     Binding="{Binding ProdutoCodigo}"                          Width="100"/>
                        <DataGridTextColumn Header="Produto"    Binding="{Binding ProdutoNome}"                            Width="*"/>
                        <DataGridTextColumn Header="Qtd"        Binding="{Binding Quantidade}"                             Width="60"/>
                        <DataGridTextColumn Header="Valor Unit." Binding="{Binding ValorUnitario, StringFormat=R$ {0:N2}}" Width="110"/>
                        <DataGridTextColumn Header="Subtotal"   Binding="{Binding Subtotal, StringFormat=R$ {0:N2}}"       Width="110"/>
                        <DataGridTemplateColumn Header="" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Remover"
                                            Style="{StaticResource GridActionButton}"
                                            CommandParameter="{Binding}"
                                            Command="{Binding DataContext.RemoverItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

 
                <Grid Grid.Row="4" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <Label    Grid.Column="0" Content="Forma Pagamento:"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding FormasPagamento}"
                              SelectedItem="{Binding PedidoAtual.FormaPagamento}"
                              IsEnabled="{Binding PodeEditar}"/>
                    <Label    Grid.Column="2" Content="Total:" FontWeight="Bold" HorizontalContentAlignment="Right"/>
                    <TextBox  Grid.Column="3" Style="{StaticResource ReadOnlyTextBox}"
                              FontWeight="Bold" HorizontalContentAlignment="Right"
                              Text="{Binding PedidoAtual.ValorTotal, StringFormat=R$ {0:N2}, Mode=OneWay}"/>
                </Grid>

                  <Grid Grid.Row="5" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <Label   Grid.Column="0" Content="Data Venda:"/>
                    <TextBox Grid.Column="1" Style="{StaticResource ReadOnlyTextBox}"
                             Text="{Binding PedidoAtual.DataVenda, StringFormat=dd/MM/yyyy HH:mm, Mode=OneWay}"/>
                    <Label   Grid.Column="2" Content="Status:" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="3" Style="{StaticResource ReadOnlyTextBox}"
                             Text="{Binding PedidoAtual.StatusTexto, Mode=OneWay}"/>
                </Grid>

                <StackPanel Grid.Row="6" Style="{StaticResource ActionBar}">
                    <Button Content="Novo Pedido" Command="{Binding NovoPedidoCommand}"/>
                    <Button Content="Finalizar"   Command="{Binding FinalizarCommand}"
                            Style="{StaticResource PrimaryButton}" MinWidth="120"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Column="2" Header="Pedidos Cadastrados">
            <DataGrid ItemsSource="{Binding Pedidos}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"         Binding="{Binding Id}"                                          Width="50"/>
                    <DataGridTextColumn Header="Pessoa"     Binding="{Binding PessoaNome}"                                  Width="*"/>
                    <DataGridTextColumn Header="Data"       Binding="{Binding DataVenda, StringFormat=dd/MM/yyyy HH:mm}"    Width="130"/>
                    <DataGridTextColumn Header="Total"      Binding="{Binding ValorTotal, StringFormat=R$ {0:N2}}"          Width="110"/>
                    <DataGridTextColumn Header="Pagamento"  Binding="{Binding FormaPagamento}"                              Width="110"/>
                    <DataGridTextColumn Header="Dt. Pagto"  Binding="{Binding DataPagamento, StringFormat=dd/MM/yyyy}" Width="130"/>
                    <DataGridTextColumn Header="Status"     Binding="{Binding StatusTexto}"                                 Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>
