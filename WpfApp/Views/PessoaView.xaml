<UserControl x:Class="WpfApp.Views.PessoaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="clr-namespace:WpfApp.Models">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="140"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Filtros">
            <StackPanel Orientation="Horizontal">
                <Label Content="Nome:" Width="60"/>
                <TextBox Width="240" Text="{Binding FiltroNome, UpdateSourceTrigger=PropertyChanged, Delay=300}"/>
                <Label Content="CPF:" Width="50" Margin="12,0,3,0"/>
                <TextBox Width="180" Text="{Binding FiltroCpf, UpdateSourceTrigger=PropertyChanged, Delay=300}"/>
            </StackPanel>
        </GroupBox>


        <GroupBox Grid.Row="1" Header="Dados da Pessoa">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label  Grid.Row="0" Grid.Column="0" Content="ID:"/>
                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource ReadOnlyTextBox}"
                         Text="{Binding EmEdicao.Id, Mode=OneWay}"/>
                <Label  Grid.Row="0" Grid.Column="2" Content="Nome:"/>
                <TextBox Grid.Row="0" Grid.Column="3"
                         IsEnabled="{Binding EmModoEdicao}"
                         Text="{Binding EmEdicao.Nome, UpdateSourceTrigger=PropertyChanged}"/>
                <Label  Grid.Row="0" Grid.Column="4" Content="CPF:"/>
                <TextBox Grid.Row="0" Grid.Column="5"
                         IsEnabled="{Binding EmModoEdicao}"
                         Text="{Binding EmEdicao.Cpf, UpdateSourceTrigger=PropertyChanged}"/>

                <Label  Grid.Row="1" Grid.Column="0" Content="Endereço:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5"
                         IsEnabled="{Binding EmModoEdicao}"
                         Text="{Binding EmEdicao.Endereco, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="2" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Incluir Pedido" Command="{Binding IncluirPedidoCommand}"
                        Style="{StaticResource AccentButton}"/>
            </StackPanel>
            <StackPanel Style="{StaticResource ActionBar}">
                <Button Content="Incluir" Command="{Binding IncluirCommand}"/>
                <Button Content="Editar"  Command="{Binding EditarCommand}"/>
                <Button Content="Salvar"  Command="{Binding SalvarCommand}"  Style="{StaticResource PrimaryButton}"/>
                <Button Content="Excluir" Command="{Binding ExcluirCommand}" Style="{StaticResource DangerButton}"/>
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Pessoas}"
                  SelectedItem="{Binding PessoaSelecionada}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"       Binding="{Binding Id}"       Width="60"/>
                <DataGridTextColumn Header="Nome"     Binding="{Binding Nome}"     Width="*"/>
                <DataGridTextColumn Header="CPF"      Binding="{Binding Cpf}"      Width="160"/>
                <DataGridTextColumn Header="Endereço" Binding="{Binding Endereco}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="4" Header="Pedidos da Pessoa - Filtros">
            <StackPanel Orientation="Horizontal">
                <Label    Content="Status:" Width="60"/>
                <ComboBox Width="260"
                          ItemsSource="{Binding OpcoesFiltroPedido}"
                          SelectedItem="{Binding FiltroPedidoSelecionado}"
                          DisplayMemberPath="Texto"/>
            </StackPanel>
        </GroupBox>

        <Label Grid.Row="5" Content="Pedidos da Pessoa selecionada:" FontWeight="Bold" Margin="0,0,0,4"/>

        <!-- Grid de pedidos da pessoa -->
        <DataGrid Grid.Row="6"
                  ItemsSource="{Binding PedidosDaPessoa}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EstaPago}" Value="True">
                            <Setter Property="Background" Value="#D4EDDA"/>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding EstaPago}" Value="False"/>
                                <Condition Binding="{Binding Status}"   Value="{x:Static m:StatusPedido.Enviado}"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#F8D7DA"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding EstaPago}" Value="False"/>
                                <Condition Binding="{Binding Status}"   Value="{x:Static m:StatusPedido.Recebido}"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#F8D7DA"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"              Binding="{Binding Id}"                                          Width="60"/>
                <DataGridTextColumn Header="Data Venda"      Binding="{Binding DataVenda, StringFormat=dd/MM/yyyy HH:mm}"    Width="140"/>
                <DataGridTextColumn Header="Valor Total"     Binding="{Binding ValorTotal, StringFormat=R$ {0:N2}}"          Width="120"/>
                <DataGridTextColumn Header="Forma Pagamento" Binding="{Binding FormaPagamento}"                              Width="140"/>
                <DataGridTextColumn Header="Dt. Pagto"       Binding="{Binding DataPagamento, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                <DataGridTextColumn Header="Status"          Binding="{Binding StatusTexto}"                                 Width="110"/>
                <DataGridTemplateColumn Header="Ações" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button CommandParameter="{Binding}"
                                        Command="{Binding DataContext.MarcarPagoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GridActionButton}">
                                            <Setter Property="Content" Value="Não pago"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataPagamento}" Value="{x:Null}">
                                                    <Setter Property="Content" Value="Pago"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Enviado"  Style="{StaticResource GridActionButton}"
                                        CommandParameter="{Binding}"
                                        Command="{Binding DataContext.MarcarEnviadoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <Button Content="Recebido" Style="{StaticResource GridActionButton}"
                                        CommandParameter="{Binding}"
                                        Command="{Binding DataContext.MarcarRecebidoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
